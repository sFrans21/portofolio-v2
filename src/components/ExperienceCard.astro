---
interface Props {
      title: string;
      company: string;
      start: string;
      end: strnig;
      points: string[];
      index: number;
}

const { title, company, start, end, points, index } = Astro.props;
---

<div class="experience-item slide-up" style={`animation-delay: ${index * 0.08}s`}>
  <div class="experience-meta">
    <span class="experience-timeline">{start} — {end}</span>
  </div>
  <div class="experience-body">
    <div class="experience-header">
      <span class="experience-title">{title}</span>
      <span class="experience-company">· {company}</span>
    </div>
    <ul class="experience-points">
      {points.map((point) => (
        <li>{point}</li>
      ))}
    </ul>
  </div>
</div>

<style>
  .experience-item {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .experience-item:last-child {
    border-bottom: none;
  }

  .experience-timeline {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--tertiary-text);
    letter-spacing: 0.02em;
    padding-top: 0.2rem;
    line-height: 1.5;
  }

  .experience-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
  }

  .experience-title {
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--primary-text);
    letter-spacing: -0.01em;
  }

  .experience-company {
    font-size: var(--font-size-small);
    color: var(--tertiary-text);
  }

  .experience-points {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .experience-points li {
    font-size: var(--font-size-small);
    color: var(--secondary-text);
    line-height: 1.65;
    padding-left: 1rem;
    position: relative;
  }

  .experience-points li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--tertiary-text);
    font-size: 0.65rem;
    top: 0.35rem;
  }

  @media (max-width: 768px) {
    .experience-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
